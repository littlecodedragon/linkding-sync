{
  "manifest_version": 3,
  "name": "Linkding Bookmark Sync",
  "version": "0.2.0",
  "description": "Sync a Linkding server with a Linkding bookmark folder in your browser.",
  "author": "Alessandro Molina",
  "homepage_url": "https://codeberg.org/Inlinestyle/linkding-sync",
  "browser_specific_settings": {
    "gecko": {
      "id": "{77a85a31-8247-498c-a898-a060e3b0b46d}",
      "strict_min_version": "120.0"
    }
  },
  "icons": {
    "48": "icons/logo_48x48.png",
    "96": "icons/logo_96x96.png",
    "128": "icons/logo_128x128.png"
  },
  "background": {
    "service_worker": "build/background.js",
    "scripts": [
      "build/background.js"
    ],
    "preferred_environment": [
      "service_worker",
      "document"
    ]
  },
  "action": {
    "default_icon": {
      "19": "icons/button_19x19.png",
      "32": "icons/button_32x32.png",
      "38": "icons/button_38x38.png"
    },
    "default_title": "Linkding Bookmark Sync",
    "default_popup": "popup/index.html"
  },
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "permissions": [
    "bookmarks",
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
